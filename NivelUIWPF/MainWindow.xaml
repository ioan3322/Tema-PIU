<Window x:Class="NivelUIWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Farmacie" Height="600" Width="900" MinWidth="600" MinHeight="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#f0f0f0" Margin="0,0,5,0">
            <Label Content="Meniu" FontWeight="Bold" FontSize="16" Margin="10"/>
            <Button Content="Administrare" Margin="10,5" Padding="5" Click="BtnAdministrare_Click"/>
            <Button Content="Cautare" Margin="10,5" Padding="5" Click="BtnCautare_Click"/>
        </StackPanel>

        <Grid Grid.Column="1" x:Name="PanelAdministrare" Margin="10" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Date Medicament" Grid.Row="0" Margin="0,0,0,10">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label x:Name="lblNume" Content="Nume:" Grid.Row="0" Grid.Column="0" Margin="5"/>
                    <TextBox x:Name="txtNume" Grid.Row="0" Grid.Column="1" Margin="5" Padding="2"
                             Text="{Binding CurrentMedicament.Nume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Producator:" Grid.Row="0" Grid.Column="2" Margin="5"/>
                    <TextBox x:Name="txtProducator" Grid.Row="0" Grid.Column="3" Margin="5" Padding="2"
                             Text="{Binding CurrentMedicament.Producator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label x:Name="lblPret" Content="Pret:" Grid.Row="1" Grid.Column="0" Margin="5"/>
                    <TextBox x:Name="txtPret" Grid.Row="1" Grid.Column="1" Margin="5" Padding="2"
                             Text="{Binding PretText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Categorie:" Grid.Row="1" Grid.Column="2" Margin="5"/>
                    <ComboBox x:Name="cmbCategorie" Grid.Row="1" Grid.Column="3" Margin="5"
                              SelectedItem="{Binding CurrentMedicament.Categorie, Mode=TwoWay}"/>

                    <Label Content="Data Expirare:" Grid.Row="2" Grid.Column="0" Margin="5"/>
                    <DatePicker x:Name="dpDataExpirare" Grid.Row="2" Grid.Column="1" Margin="5"
                                SelectedDate="{Binding CurrentMedicament.DataExpirare, Mode=TwoWay}"/>

                    <Label Content="Optiuni:" Grid.Row="2" Grid.Column="2" Margin="5"/>
                    <StackPanel Grid.Row="2" Grid.Column="3" Margin="5" Orientation="Vertical">
                        <RadioButton x:Name="rbReteta" Content="Reteta Necesara" GroupName="OptiuniGrp"/>
                        <RadioButton x:Name="rbFaraReteta" Content="Fara Reteta" GroupName="OptiuniGrp" IsChecked="True"/>
                        <CheckBox x:Name="chkCompensat" Content="Compensat" Margin="0,5,0,0"/>
                        <CheckBox x:Name="chkGeneric" Content="Generic" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Adauga" Padding="15,5" Margin="5" Click="BtnAdauga_Click"/>
                        <Button Content="Modifica" Padding="15,5" Margin="5" Click="BtnModifica_Click"/>
                        <Button Content="Curata" Padding="15,5" Margin="5" Click="BtnCurata_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <DataGrid x:Name="dgMedicamente" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"
                      ItemsSource="{Binding MedicamenteList}" SelectionChanged="DgMedicamente_SelectionChanged"/>
        </Grid>

        <Grid Grid.Column="1" x:Name="PanelCautare" Margin="10" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Filtre Cautare" Grid.Row="0" Margin="0,0,0,10">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Cauta (Nume/Producator):" Margin="0,0,5,0"/>
                    <TextBox x:Name="txtTermenCautare" Grid.Column="1" Margin="5,0,0,0" Padding="2"
                             TextChanged="TxtTermenCautare_TextChanged"/>
                </Grid>
            </GroupBox>

            <DataGrid x:Name="dgRezultateCautare" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
        </Grid>
    </Grid>
</Window>
