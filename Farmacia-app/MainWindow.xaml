<Window x:Class="Farmacia_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Farmacie" Height="650" Width="980" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#334155" />
            <Setter Property="Margin" Value="10,6" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#DC2626" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#0F766E" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <TextBlock Text="Gestiune medicamente" FontSize="20" FontWeight="Bold" />
                    <TextBlock x:Name="StockSummaryText" Margin="20,5,0,0" Foreground="#475569" />
                </StackPanel>

                <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Client" Click="OnOpenClient" />
            </Grid>

            <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Nume:" VerticalAlignment="Center" />
                    <TextBox x:Name="NameBox" Width="180" Margin="6,0,12,0" />

                    <TextBlock Text="Pret:" VerticalAlignment="Center" />
                    <TextBox x:Name="PriceBox" Width="100" Margin="6,0,12,0" />

                    <TextBlock Text="Stoc:" VerticalAlignment="Center" />
                    <TextBox x:Name="StockBox" Width="80" Margin="6,0,12,0" />

                    <Button Style="{StaticResource ActionButtonStyle}" Content="Adauga" Click="OnAdd" />
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Editeaza" Click="OnUpdate" />
                    <Button Style="{StaticResource DangerButtonStyle}" Content="Sterge" Click="OnDelete" />
                </StackPanel>
            </Border>

            <DataGrid x:Name="MedicamenteGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="OnSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                    <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="*" />
                    <DataGridTextColumn Header="Pret" Binding="{Binding Pret}" Width="120" />
                    <DataGridTextColumn Header="Stoc" Binding="{Binding Stoc}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="3" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Cautare:" VerticalAlignment="Center" />
                    <TextBox x:Name="SearchBox" Width="220" Margin="6,0,12,0" />
                    <Button Style="{StaticResource ActionButtonStyle}" Content="Cauta" Click="OnSearch" />
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Reset" Click="OnReset" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
