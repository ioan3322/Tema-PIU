<Window x:Class="Farmacia_app.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Farmacie" Height="420" Width="520" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="0,8" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0F766E" />
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Bun venit" FontSize="26" FontWeight="Bold" />
            <TextBlock Text="Alege modul de lucru" FontSize="14" Foreground="#475569" />
        </StackPanel>

        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="24">
            <StackPanel>
                <TextBlock Text="Administrare" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="Gestionare medicamente, stoc, editare." Margin="0,4,0,12" Foreground="#475569" />
                <Button Style="{StaticResource PrimaryButton}" Content="Intra ca Administrator" Click="OnOpenAdmin" />

                <Separator Margin="0,20" />

                <TextBlock Text="Client" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="Cauta si cumpara medicamente." Margin="0,4,0,12" Foreground="#475569" />
                <Button Style="{StaticResource SecondaryButton}" Content="Intra ca Client" Click="OnOpenClient" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
