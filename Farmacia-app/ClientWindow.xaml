<Window x:Class="Farmacia_app.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client Farmacie" Height="620" Width="920" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#0F766E" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Client - cauta si cumpara" FontSize="20" FontWeight="Bold" />
        </StackPanel>

        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Cautare:" VerticalAlignment="Center" />
                <TextBox x:Name="SearchBox" Width="220" Margin="6,0,12,0" />
                <Button Style="{StaticResource ActionButtonStyle}" Content="Cauta" Click="OnSearch" />
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Reset" Click="OnReset" />
            </StackPanel>
        </Border>

        <DataGrid x:Name="MedicamenteGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="OnSelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="*" />
                <DataGridTextColumn Header="Pret" Binding="{Binding Pret}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Selectat:" VerticalAlignment="Center" />
                <TextBlock x:Name="SelectedText" Margin="6,0,12,0" VerticalAlignment="Center" />

                <TextBlock Text="Cantitate:" VerticalAlignment="Center" />
                <TextBox x:Name="QuantityBox" Width="80" Margin="6,0,12,0" />

                <Button Style="{StaticResource ActionButtonStyle}" Content="Cumpara" Click="OnBuy" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
